---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { tagToParam } from '../../lib/blogTaxonomy';
import { joinBasePath } from '../../utils/siteBaseUrl';

const posts = await getCollection('blog');
const tagCounts = new Map<string, number>();
for (const p of posts) {
	for (const t of p.data.tags) {
		if (!t || t.includes('/')) continue;
		tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
	}
}
const tagsSorted = [...tagCounts.entries()].sort((a, b) => a[0].localeCompare(b[0]));

const title = `Tags — ${SITE_TITLE}`;
const description = 'Browse posts by tag.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
			}
			h1 {
				font-size: 1.75rem;
				margin-bottom: 1rem;
			}
			ul {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			li {
				margin-bottom: 0.5rem;
			}
			a {
				color: rgb(var(--accent));
				text-decoration: none;
			}
			a:hover {
				text-decoration: underline;
			}
			.count {
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Tags</h1>
			<ul>
				{
					tagsSorted.map(([tag, count]) => (
						<li>
							<a href={`${joinBasePath(`tags/${tagToParam(tag)}`)}/`}>{tag}</a>
							<span class="count"> ({count})</span>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
