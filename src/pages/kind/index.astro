---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import {
	ARTICLE_KINDS,
	ARTICLE_KIND_LABELS,
	type ArticleKind,
} from '../../lib/blogTaxonomy';
import { joinBasePath } from '../../utils/siteBaseUrl';

const posts = await getCollection('blog');
const counts: Record<ArticleKind, number> = {
	'weekly-brief': 0,
	spotlight: 0,
};
for (const p of posts) {
	counts[p.data.articleKind]++;
}

const title = `Article kinds — ${SITE_TITLE}`;
const description = 'Browse posts by article kind (weekly brief or spotlight).';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
			}
			h1 {
				font-size: 1.75rem;
				margin-bottom: 1rem;
			}
			ul {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			li {
				margin-bottom: 0.65rem;
			}
			a {
				color: rgb(var(--accent));
				text-decoration: none;
			}
			a:hover {
				text-decoration: underline;
			}
			.count {
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Article kinds</h1>
			<ul>
				{
					ARTICLE_KINDS.map((k) => (
						<li>
							<a href={`${joinBasePath(`kind/${k}`)}/`}>{ARTICLE_KIND_LABELS[k]}</a>
							<span class="count"> ({counts[k]})</span>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
